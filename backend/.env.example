# Backend configuration — copy to backend/.env and fill in real values.

# --- Server ---
PORT=3000
LOG_LEVEL=warn            # error | warn | info | debug
NODE_ENV=development      # set to "production" when deployed

# --- Device ---
CLEARLIGHT_IP=10.0.0.50   # IP address of the Clearlight sauna controller

# --- Authentication ---
API_TOKEN=change-me-to-a-random-secret   # Bearer token (Authorization header + Socket.IO auth)
API_KEY=change-me-to-a-url-key           # token for ?token= query-param auth (automation)

# --- CORS ---
# Comma-separated allowed origins; supports wildcard ports (http://host:*)
ALLOWED_ORIGINS=http://localhost,http://localhost:*

# --- Web Push (optional; run `node generate-vapid-keys.js` to create keys) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# --- InfluxDB stats logging (optional; all four required to enable) ---
# Logs current_temp, set_temp, power_flag, pre_time_flag for heat-up timing.
INFLUX_URL=http://influxdb.local:8086
INFLUX_TOKEN=
INFLUX_ORG=
INFLUX_BUCKET=sauna
INFLUX_DEVICE=clearlight              # tag value applied to every point
INFLUX_MEASUREMENT=sauna              # measurement name
INFLUX_SAMPLE_INTERVAL_MS=15000       # min ms between samples (state changes always logged)
