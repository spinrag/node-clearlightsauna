# Backend
PORT=3000                                          # HTTP server port
CLEARLIGHT_IP=192.168.1.100                        # Sauna device IP on your LAN
API_TOKEN=change-me-to-a-random-secret             # Shared auth token (used by both backend and frontend)
ALLOWED_ORIGINS=http://localhost:8099,http://localhost:3000  # Comma-separated CORS origins (supports wildcards: *.example.com, localhost:*)
LOG_LEVEL=info                                     # Winston log level: error, warn, info, debug
NODE_ENV=development                               # Set to "production" in prod

# Frontend (Vite — VITE_* vars are embedded in the client bundle)
VITE_SOCKET_HOST=http://localhost:3000             # Backend URL the frontend connects to
VITE_API_TOKEN=change-me-to-a-random-secret        # Must match API_TOKEN above
VITE_DEV_MODE=true                                 # Show debug JSON panel in the UI
