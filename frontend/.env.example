# Frontend configuration — copy to frontend/.env and fill in.
# Vite loads this from the frontend/ directory; VITE_* vars are embedded into
# the client bundle at build time (do not put real secrets here).

VITE_SOCKET_HOST=http://localhost:3000   # Backend URL the browser connects to (use your LAN IP/host in prod)
VITE_API_TOKEN=change-me-to-a-random-secret   # Must match the backend API_TOKEN
VITE_DEV_MODE=true                       # Show the debug status JSON panel in the UI

# PORT is read by vite (dev/preview server), not VITE_-prefixed:
# PORT=8099
